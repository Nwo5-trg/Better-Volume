{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nwo5.better_volume",
	"name": "Better Volume",
	"version": "v2.0.0",
	"developers": ["Nwo5","lyyako"],
	"description": "Like the alpha mod kinda but cooler.",
	"tags": ["offline", "enhancement", "interface", "utility", "customization"],
	"links": {"source": "https://github.com/Nwo5-trg/Better-Volume"},
	"dependencies": {
		"geode.node-ids": ">=1.22.0"
	},
	"incompatibilities": {
		"alphalaneous.volume_input": "*"
	},
	"settings": {
		"colored-bars": {
			"type": "bool",
			"name": "Colored Bars",
			"default": true
		},
		"music-color": {
			"type": "rgb",
			"name": "Music Color",
			"default": "#007dff"
		},
		"sfx-color": {
			"type": "rgb",
			"name": "SFX Color",
			"default": "#00ff7b"
		}
	}
}
