{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nwo5.better_volume",
	"name": "Better Volume",
	"version": "v2.1.1",
	"developers": ["Nwo5","lyyako"],
	"description": "like the alpha mod kinda but cooler :3c",
	"tags": ["offline", "enhancement", "interface", "utility", "customization"],
	"links": {
		"source": "https://github.com/Nwo5-trg/Better-Volume",
		"community": "https://discord.gg/AeFeYWGUxZ"
	},
	"dependencies": {
		"geode.node-ids": ">=1.23.3",
		"nwo5.silly-api": ">=1.3.0"
	},
	"incompatibilities": {
		"alphalaneous.volume_input": ">=v1.0.0"
	},
	"settings": {
		"title-general": {
			"name": "General",
			"type": "title"
		},
		"enabled": {
			"type": "bool",
			"name": "Enabled",
			"default": true
		},
		"title-functionality": {
			"name": "Functionality",
			"type": "title"
		},
		"input-precision": {
			"type": "int",
			"name": "Input Precision",
			"min": 0,
			"max": 5,
			"default": 0
		},
		"swap-sliders": {
			"type": "bool",
			"name": "Swap Sliders",
			"default": false
		},
		"mute-button": {
			"type": "bool",
			"name": "Mute Button",
			"default": true
		},
		"mute-button-on-right": {
			"type": "bool",
			"name": "Mute Button On Right",
			"default": true,
			"enable-if": "mute-button"
		},

		"title-visual": {
			"name": "Visual",
			"type": "title"
		},
		"colored-bars": {
			"type": "bool",
			"name": "Colored Bars",
			"default": true
		},
		"music-color": {
			"type": "rgb",
			"name": "Music Color",
			"default": "#00ff7b",
			"enable-if": "colored-bars"
		},
		"sfx-color": {
			"type": "rgb",
			"name": "SFX Color",
			"default": "#007dff",
			"enable-if": "colored-bars"
		},
		"music-text": {
			"type": "string",
			"name": "Custom Music Text",
			"default": "Music:",
			"filter": "1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ`1234567890-=[]\\;',./~!@#$%^&*()_+{}|:\"<>?"
		},
		"sfx-text": {
			"type": "string",
			"name": "Custom SFX Text",
			"default": "SFX:",
			"filter": "1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ`1234567890-=[]\\;',./~!@#$%^&*()_+{}|:\"<>?"
		}
	}
}